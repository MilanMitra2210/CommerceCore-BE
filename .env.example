# ==============================================================================
# CommerceCore Backend — Environment Variables
# ==============================================================================
# Copy this file to .env and fill in the values.
# Never commit the .env file to version control.
# ==============================================================================

# ---- PostgreSQL ----
POSTGRES_DB=commercecore_db
POSTGRES_USER=commercecore
POSTGRES_PASSWORD=commercecore_secret
POSTGRES_PORT=5433

# ---- Redis ----
REDIS_PORT=6379

# ---- Application (used in production profile) ----
DB_HOST=localhost
DB_PORT=5432
DB_NAME=commercecore_db
DB_USERNAME=commercecore
DB_PASSWORD=commercecore_secret

REDIS_HOST=localhost
REDIS_REDIS_PORT=6379

# ---- CORS ----
CORS_ALLOWED_ORIGINS=http://localhost:3002,http://localhost:5173

# ---- JWT (configure when building Auth module) ----
# JWT_SECRET=your-256-bit-secret
# JWT_ACCESS_EXPIRATION_MS=900000
# JWT_REFRESH_EXPIRATION_MS=604800000
